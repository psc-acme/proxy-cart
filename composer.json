{
    "name": "psc-acme/proxy-cart",
    "description": "Package proxy-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProxyCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/lock": "^7.0",
        "illuminate/support": "^11.0",
        "psc-acme/lib-cart": "^1.0"
    },
    "require-dev": {
        "webforge/object-asserter": "^2.0.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}